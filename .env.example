# ─────────────────────────────────────────────────────────────
#  PulseBoard Environment Configuration
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
# Port nginx listens on (default: 80)
PORT=80

# Node environment: development | production
NODE_ENV=production

# ── Authentication ────────────────────────────────────────────
# JWT signing secret — change this to a long random string in production
# Generate one: openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_32_chars

# ── Database ──────────────────────────────────────────────────
# SQLite database file path inside the backend container
# The pb_data volume is mounted to /app/data
DB_PATH=/app/data/pulseboard.db

# ── CORS ─────────────────────────────────────────────────────
# Allowed origins for the API (use your production domain)
# Example: https://pulseboard.yourdomain.com
CORS_ORIGIN=*

# ── Frontend (build-time Vite vars) ──────────────────────────
# If deploying frontend separately, set the backend API URL here
# VITE_API_URL=https://api.yourdomain.com

# ── Stripe Billing ────────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Webhook secret — Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Endpoint URL: https://yourdomain.com/api/billing/webhook
# Subscribe to: customer.subscription.created, customer.subscription.updated,
#   customer.subscription.deleted, checkout.session.completed,
#   invoice.payment_succeeded, invoice.payment_failed,
#   customer.subscription.trial_will_end
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs — Stripe Dashboard → Products → create 3 recurring monthly prices
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxx   # $49/mo
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxxxxxxxxxxxxxx    # $99/mo
STRIPE_PRICE_AGENCY=price_xxxxxxxxxxxxxxxxxxxxxxxx    # $199/mo

# Your app's public URL (used for Stripe redirect after checkout)
APP_URL=http://localhost:3000

# ── Email Notifications (Resend) ─────────────────────────────
# Sign up free at resend.com — 3,000 emails/month on free tier
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# From address — must be from a verified domain in Resend
EMAIL_FROM=PulseBoard <noreply@yourdomain.com>
